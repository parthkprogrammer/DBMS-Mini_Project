<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="600.0" prefWidth="800.0" styleClass="dashboard-bg" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sms.controller.DashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" styleClass="top-bar">
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
         </padding>
         <children>
            <Label text="Student Management System" styleClass="header-text" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel" text="Welcome, User!" styleClass="sub-header-text" />
         </children>
      </HBox>
   </top>
   <left>
      <VBox spacing="10.0" styleClass="sidebar" prefWidth="200.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" top="20.0" />
         </padding>
         <children>
            <VBox alignment="CENTER" spacing="5.0">
                <children>
                    <Label text="MENU" styleClass="sidebar-title" />
                    <Label fx:id="roleLabel" text="Role: " styleClass="sidebar-text" />
                </children>
                <VBox.margin>
                   <Insets bottom="30.0" />
                </VBox.margin>
            </VBox>
            
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Home" onAction="#handleHome" styleClass="sidebar-button" />
            <Button fx:id="coursesButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Courses" onAction="#handleCourses" styleClass="sidebar-button" />
            <Button fx:id="gradesButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Grades" onAction="#handleGrades" styleClass="sidebar-button" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" text="Logout" styleClass="logout-button">
               <VBox.margin>
                  <Insets left="20.0" right="20.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <VBox fx:id="contentArea" alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         <children>
             <VBox alignment="CENTER" styleClass="dashboard-card" maxWidth="500.0">
                 <children>
                    <Label fx:id="dashboardContentLabel" text="Welcome to your Dashboard. Select an option from the menu." styleClass="sub-header-text" wrapText="true" textAlignment="CENTER" />
                 </children>
             </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
